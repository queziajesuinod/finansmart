# ─── Servidor ───────────────────────────────────────────────
PORT=3333
NODE_ENV=development
FRONTEND_URL=http://127.0.0.1:4173

# ─── Banco de dados (PostgreSQL) ────────────────────────────
# Opção A: URL única (tem prioridade se preenchida)
# DATABASE_URL=postgres://usuario:senha@host:5432/banco
# Opção B: campos separados
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=finansmart
# Opcional: usar um schema específico (cria se não existir)
# DB_SCHEMA=dev

# ─── Cobrança ───────────────────────────────────────────────
# false = modo teste: todos os usuários ficam liberados com todos os módulos.
# true  = valem as assinaturas (Fase 2 / Stripe).
BILLING_ENABLED=false

# ─── Autenticação ───────────────────────────────────────────
JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio
JWT_EXPIRES_IN=7d

# Google OAuth (deixe vazio para desativar o login com Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://127.0.0.1:3333/auth/google/callback

# ─── Stripe (usado na Fase 2) ───────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
